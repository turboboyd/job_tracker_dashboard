{
  "name": "job-tracker-dashboard",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "cross-env TS_NODE_PROJECT=tsconfig.node.json webpack serve --mode development --config config/webpack.config.cjs",
    "build": "cross-env TS_NODE_PROJECT=tsconfig.node.json webpack --mode production --config config/webpack.config.cjs",
    "test:auth": "node scripts/run-ts-tests.cjs src/features/auth src/entities/auth",
    "test:core": "node scripts/run-ts-tests.cjs src/entities/application src/pages/DashboardPage src/pages/BoardPage src/pages/AccountSettingsPage src/pages/MatchesPage src/pages/ApplicationsPage src/shared/lib/cvScoring",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "check:deps": "depcruise src --config .dependency-cruiser.js --output-type err",
    "check:dup": "jscpd src",
    "check:cycles": "madge --circular --extensions ts,tsx --ts-config tsconfig.json src",
    "check:scripts": "node scripts/check-package-scripts.mjs",
    "check:local-imports": "node scripts/check-local-imports.mjs",
    "check:layer-boundaries": "node scripts/check-layer-boundaries.mjs",
    "check": "npm run typecheck && npm run lint && npm run test:auth && npm run test:core && npm run check:scripts && npm run check:i18n && npm run check:docs && npm run check:doc-references && npm run check:quality-gate && npm run check:architecture",
    "dep:graph": "madge --extensions ts,tsx --ts-config tsconfig.json --image graph.svg src",
    "generate:whats-new": "node scripts/generate-whats-new.mjs",
    "check:arch": "node scripts/check-arch.mjs",
    "cleanup:refactor": "node scripts/refactor-cleanup.mjs",
    "cleanup:refactor:list": "node scripts/list-unneeded-files.mjs",
    "cleanup:repo": "node scripts/refactor-cleanup.mjs",
    "cleanup:repo:list": "node scripts/list-unneeded-files.mjs",
    "check:pages-boundaries": "node scripts/check-page-boundaries.mjs",
    "check:public-api-imports": "node scripts/check-public-api-imports.mjs",
    "check:docs": "node scripts/check-docs.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:structure-contract": "node scripts/check-structure-contract.mjs",
    "check:doc-references": "node scripts/check-doc-references.mjs",
    "check:architecture": "npm run check:structure-contract && npm run check:local-imports && npm run check:public-api-imports && npm run check:pages-boundaries && npm run check:layer-boundaries && npm run check:arch",
    "check:quality-gate": "node scripts/check-quality-gate.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@reduxjs/toolkit": "^2.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.7.0",
    "formik": "^2.4.9",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.562.0",
    "pdfjs-dist": "^4.10.38",
    "process": "^0.11.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.2",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.12.0",
    "tailwind-merge": "^3.4.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.3",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@types/node": "^25.0.6",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.23",
    "babel-loader": "^10.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "dependency-cruiser": "^17.3.7",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.3",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-webpack-plugin": "^5.0.2",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^17.3.0",
    "html-webpack-plugin": "^5.6.5",
    "jscpd": "^4.0.8",
    "madge": "^8.0.0",
    "mini-css-extract-plugin": "^2.9.4",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "react-refresh": "^0.18.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  }
}
