# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=job-tracker-api
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────────────────────
# asyncpg driver is required. Must start with postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_tracker

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. Do NOT use "*" in production.
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Firebase Auth ─────────────────────────────────────────────────────────────
# Absolute path to the Firebase service-account JSON file (Project Settings →
# Service accounts → Generate new private key).
#
# - The file MUST live outside version control. The recommended local path is
#   backend/secrets/firebaseServiceAccount.json — the backend/.gitignore rules
#   exclude that directory and common service-account filename patterns.
# - The service account MUST belong to the same Firebase project as the
#   frontend web app (see src/shared/config/firebase/app.ts). A project
#   mismatch yields a generic 401 on every protected endpoint.
# - The verifier is built lazily and cached after the first auth request, so
#   the backend process MUST be restarted after changing this value — uvicorn
#   --reload alone will not pick up the new path.
# - Leave empty to get 503 on all auth requests (useful during local dev
#   without Firebase, or to keep the unit-test process happy).
FIREBASE_CREDENTIALS_JSON_PATH=

# ── Document Storage ──────────────────────────────────────────────────────────
# Local filesystem root for uploaded documents (relative to the backend/ dir).
# The directory is created on first upload. Add backend/storage/ to .gitignore.
DOCUMENT_STORAGE_ROOT=storage/documents

# ── Testing ───────────────────────────────────────────────────────────────────
# Optional: point integration tests at a dedicated test database so that
# create_all / drop_all do not touch your development data.
# Defaults to DATABASE_URL when not set.
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_tracker_test
