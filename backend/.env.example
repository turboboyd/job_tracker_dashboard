# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=job-tracker-api
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────────────────────
# asyncpg driver is required. Must start with postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_tracker

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. Do NOT use "*" in production.
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Firebase Auth ─────────────────────────────────────────────────────────────
# Absolute path to the Firebase service-account JSON file (Project Settings →
# Service accounts → Generate new private key).
# Leave empty to get 503 on all auth requests (useful during local dev without Firebase).
FIREBASE_CREDENTIALS_JSON_PATH=

# ── Testing ───────────────────────────────────────────────────────────────────
# Optional: point integration tests at a dedicated test database so that
# create_all / drop_all do not touch your development data.
# Defaults to DATABASE_URL when not set.
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_tracker_test
