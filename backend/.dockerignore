# Environment — never embed credentials in an image
.env
*.env

# Firebase service-account keys
secrets/
*.serviceAccount*.json
*serviceAccount*.json
firebaseServiceAccount*.json
serviceAccountKey*.json

# Python build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test / coverage output (keep image lean)
tests/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
coverage/

# Local runtime data and generated artifacts
storage/
*.log
*.zip
*.tar
*.tar.gz
*.sqlite
*.db

# Editor / OS noise
.DS_Store
*.swp
.idea/
.vscode/
