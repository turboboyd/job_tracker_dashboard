# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
*.log
*.zip
.eggs/

# Virtual environments
.venv/
venv/
env/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Environment — never commit real secrets
.env
.env.*
!.env.example

# Firebase service-account keys — must never be committed.
# The convention is to place keys under backend/secrets/ (created locally
# by the developer). The pattern rules below also defend against keys
# accidentally placed elsewhere under backend/.
secrets/
storage/
*.serviceAccount*.json
*serviceAccount*.json
firebaseServiceAccount*.json
serviceAccountKey*.json
# Also match hyphen/underscore spellings (e.g. firebase-service-account.json).
*service-account*.json
*service_account*.json
