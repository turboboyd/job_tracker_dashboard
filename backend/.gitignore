# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Environment — never commit real secrets
.env

# Firebase service-account keys — must never be committed.
# The convention is to place keys under backend/secrets/ (created locally
# by the developer). The pattern rules below also defend against keys
# accidentally placed elsewhere under backend/.
secrets/
*.serviceAccount*.json
*serviceAccount*.json
firebaseServiceAccount*.json
serviceAccountKey*.json
