{
  email admin@example.com
}

api.example.com {
  encode zstd gzip

  @health path /api/v1/health /api/v1/health/ready

  reverse_proxy api:8000 {
    header_up Host {host}
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
  }
}
