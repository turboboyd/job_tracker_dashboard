APP_NAME=job-tracker-api
APP_VERSION=0.1.0
ENVIRONMENT=production
LOG_LEVEL=INFO

POSTGRES_DB=job_tracker
POSTGRES_USER=job_tracker
POSTGRES_PASSWORD=<change-me-strong-postgres-password>

DATABASE_URL=postgresql+asyncpg://job_tracker:<change-me-strong-postgres-password>@postgres:5432/job_tracker
CORS_ALLOWED_ORIGINS=https://frontend.example.com

FIREBASE_CREDENTIALS_JSON_PATH=/run/secrets/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_HOST_PATH=/opt/job-tracker-dashboard/secrets/firebase-service-account.json

DOCUMENT_STORAGE_ROOT=/app/storage/documents

CADDYFILE_HOST_PATH=/opt/job-tracker-dashboard/deploy/Caddyfile

# Discovery source adapters.
# Arbeitsagentur and Remotive can run without server secrets.
# Adzuna is skipped until both values below are set on the server.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Greenhouse and Lever use explicit company allow-lists, not broad crawling.
# Examples: GREENHOUSE_BOARD_TOKENS=company-a,company-b
# Examples: LEVER_SITE_NAMES=company-c,company-d
GREENHOUSE_BOARD_TOKENS=
LEVER_SITE_NAMES=

AI_ANALYSIS_PROVIDER=deterministic
OLLAMA_BASE_URL=http://ollama.example.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=60
